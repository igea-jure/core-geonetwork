    <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/metadata-codelist"/>
    <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/metadata-codelist"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-21</dct:created>
    <dct:format rdf:resource="http://www.iana.org/assignments/media-types/application/rdf+xml"/>
    <dct:accrualPeriodicity rdf:resource="http://publications.europa.eu/resource/authority/frequency/UNKNOWN"/>
    <dct:title xml:lang="sl">Prostorski obseg</dct:title>
    <dct:title xml:lang="en">Spatial scope</dct:title>
    <skos:prefLabel xml:lang="sl">Prostorski obseg</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Spatial scope</skos:prefLabel>
    <dct:description xml:lang="sl">Administrativna raven, ki jo zbirka podatkov namerava pokriti.</dct:description>
    <dct:description xml:lang="en">Administrative level that the data set intends to cover.</dct:description>
    <skos:definition xml:lang="sl">Administrativna raven, ki jo zbirka podatkov namerava pokriti.</skos:definition>
    <skos:definition xml:lang="en">Administrative level that the data set intends to cover.</skos:definition>
    <vann:usageNote xml:lang="en">The spatial scope can be different from the actual geographical coverage, e.g. a national coastline data set may cover only a fraction of the full spatial extent of a country. The spatial scope of the data set does not necessarily reflect the administrative level responsible for collecting and maintaining the data. The code list contains values governed at the level of INSPIRE legal acts (Legal (EU)) and values governed at the level of Technical Guidelines (Technical (EU)).</vann:usageNote>
    <dct:hasPart rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national"/>
    <dct:hasPart rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional"/>
    <dct:hasPart rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local"/>
    <dct:hasPart rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/global"/>
    <dct:hasPart rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/european"/>
    <skos:hasTopConcept rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national"/>
    <skos:hasTopConcept rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional"/>
    <skos:hasTopConcept rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local"/>
    <skos:hasTopConcept rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/global"/>
    <skos:hasTopConcept rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/european"/>
    <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
    <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national">
    <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national</dct:identifier>
    <dcat:isPartOf>
      <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/registry"/>
    </dcat:isPartOf>

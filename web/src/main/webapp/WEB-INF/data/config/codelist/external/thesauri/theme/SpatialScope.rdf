    </dcat:isPartOf>
    <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local:3"/>
    <adms:last rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local"/>
    <adms:prev rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local:1"/>
    <adms:prev rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local:2"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-22</dct:created>
    <dct:title xml:lang="sl">Lokalno</dct:title>
    <skos:prefLabel xml:lang="sl">Lokalno</skos:prefLabel>
    <dct:description xml:lang="sl">Namen zbirke podatkov je zajeti ozemlje ene ali več lokalnih upravnih enot.</dct:description>
    <skos:definition xml:lang="sl">Zbirka podatkov pokriva eno ali več občin ali podobnih lokalnih enot.</skos:definition>
    <vann:usageNote xml:lang="sl">Lokalno ozemlje obsega eno ali več občin ali drugih primerljivih lokalnih skupnosti. Zbirke podatkov, ki pokrivajo vse objekte določene teme v takšnih enotah, so lokalnega obsega.</vann:usageNote>
    <dct:title xml:lang="en">Local</dct:title>
    <skos:prefLabel xml:lang="en">Local</skos:prefLabel>
    <dct:description xml:lang="en">The data set aims to cover the territory of one or more local administrative units.</dct:description>
    <skos:definition xml:lang="en">The data set covers one or more municipalities or similar local entities.</skos:definition>
    <vann:usageNote xml:lang="en">A local territory comprises one or more municipalities or similar local communities. Datasets that cover all objects of a specific theme within these units are considered to have a local scope.</vann:usageNote>
    <skos:broader rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-technical"/>
    <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/global">
    <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/global</dct:identifier>

    <skos:prefLabel xml:lang="sl">Globalno</skos:prefLabel>
    <dct:description xml:lang="sl">Namen zbirke podatkov je zajeti celotno Zemljo.</dct:description>
    <skos:definition xml:lang="sl">Zbirka podatkov pokriva globalno ozemlje, torej celoten planet.</skos:definition>
    <vann:usageNote xml:lang="sl">Globalne zbirke podatkov vključujejo podatke, ki pokrivajo vse države ali večino sveta. Primeri vključujejo satelitske posnetke, globalne modele podnebja ipd.</vann:usageNote>
    <dct:title xml:lang="en">Global</dct:title>
    <skos:prefLabel xml:lang="en">Global</skos:prefLabel>
    <dct:description xml:lang="en">The data set aims to cover the entire Earth.</dct:description>
    <skos:definition xml:lang="en">The data set covers the global territory, i.e., the whole planet.</skos:definition>
    <vann:usageNote xml:lang="en">Global datasets include data that cover all countries or most of the world. Examples include satellite imagery, global climate models, etc.</vann:usageNote>

    </dcat:isPartOf>
    <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national:3"/>
    <adms:last rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national"/>
    <adms:prev rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national:1"/>
    <adms:prev rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/national:2"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-22</dct:created>
    <dct:title xml:lang="sl">Nacionalno</dct:title>
    <skos:prefLabel xml:lang="sl">Nacionalno</skos:prefLabel>
    <dct:description xml:lang="sl">Namen zbirke podatkov je zajeti nacionalno ozemlje.</dct:description>
    <skos:definition xml:lang="sl">Namen zbirke podatkov je zajeti nacionalno ozemlje.</skos:definition>
    <vann:usageNote xml:lang="sl">Zbirke podatkov, ki vsebujejo vse objekte določene teme na nacionalnem ozemlju, so zbirke podatkov nacionalnega obsega. Območje, ki ga zajema taka zbirka, se lahko razlikuje od dejanskega geografskega območja nacionalnega ozemlja. Nacionalno ozemlje je lahko razdeljeno na več enot, npr. regije, občine itd.</vann:usageNote>
    <dct:title xml:lang="en">National</dct:title>
    <skos:prefLabel xml:lang="en">National</skos:prefLabel>
    <dct:description xml:lang="en">The data set aims to cover the national territory.</dct:description>
    <skos:definition xml:lang="en">The data set aims to cover the national territory.</skos:definition>
    <vann:usageNote xml:lang="en">Datasets that include all objects of a certain theme on the national territory are considered datasets of national scope. The coverage area may differ from the actual geographical extent. The national territory may be subdivided into multiple units such as regions or municipalities.</vann:usageNote>
    <skos:broader rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-legal"/>
    <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional">
    <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional</dct:identifier>
    <dcat:isPartOf>
      <dcat:Catalog rdf:about="http://inspire.ec.europa.eu/registry"/>
    </dcat:isPartOf>
    <dcat:isPartOf>

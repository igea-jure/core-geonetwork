    </dcat:isPartOf>
    <owl:sameAs rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional:3"/>
    <adms:last rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional"/>
    <adms:prev rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional:1"/>
    <adms:prev rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/regional:2"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <skos:topConceptOf rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-22</dct:created>
    <dct:title xml:lang="sl">Regionalno</dct:title>
    <skos:prefLabel xml:lang="sl">Regionalno</skos:prefLabel>
    <dct:description xml:lang="sl">Namen zbirke podatkov je zajeti ozemlje ene ali več upravnih enot na podnacionalni ravni.</dct:description>
    <skos:definition xml:lang="sl">Zbirka podatkov pokriva eno ali več regij znotraj države članice.</skos:definition>
    <vann:usageNote xml:lang="sl">Regionalno ozemlje je sestavljeno iz več območij, kot so regije, pokrajine ali druge enote na podnacionalni ravni. Zbirke podatkov, ki zajemajo vse objekte določene teme v eni ali več takšnih enotah, so zbirke regionalnega obsega.</vann:usageNote>
    <dct:title xml:lang="en">Regional</dct:title>
    <skos:prefLabel xml:lang="en">Regional</skos:prefLabel>
    <dct:description xml:lang="en">The data set aims to cover the territory of one or more administrative units at the sub-national level.</dct:description>
    <skos:definition xml:lang="en">The data set covers one or more regions within a member state.</skos:definition>
    <vann:usageNote xml:lang="en">A regional territory is composed of one or more areas such as regions, provinces or other sub-national units. Datasets covering all objects of a given theme in one or more such units are considered to have a regional scope.</vann:usageNote>
    <skos:broader rdf:resource="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope"/>
    <rdfs:isDefinedBy rdf:resource="http://inspire.ec.europa.eu/registry/governance-level/eu-legal"/>
    <adms:status rdf:resource="http://inspire.ec.europa.eu/registry/status/valid"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local">
    <dct:identifier rdf:datatype="http://www.w3.org/2000/01/rdf-schema#Literal">http://inspire.ec.europa.eu/metadata-codelist/SpatialScope/local</dct:identifier>
    <dcat:isPartOf>
